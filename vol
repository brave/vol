def create_volume(tags, snapshot, availability_zone, size, kms_key_id, volume_initialization_rate):
    if get_volumes(tags, availability_zone) != []:
        err('TOO_MANY_VOLUMES')

    msg(f'Creating a volume with tags {get_tag_string(tags)} ' +
       (f'from snapshot {snapshot["SnapshotId"]} with tags {get_tag_string(snapshot["Tags"])}' if snapshot else ''))

    options = {
        'AvailabilityZone': availability_zone,
        'Encrypted': True,
        'Size': size,
        'TagSpecifications': [{'ResourceType': 'volume', 'Tags': get_tag_spec(tags)}],
        'VolumeType': 'gp3',
    } | ({'KmsKeyId': kms_key_id} if kms_key_id else {}) \
      | ({'SnapshotId': snapshot['SnapshotId']} if snapshot else {}) \
      | ({'VolumeInitializationRate': volume_initialization_rate} if volume_initialization_rate and snapshot else {})

    volume = client('ec2').create_volume(**options)
    update_timestamp(volume['VolumeId'])

    return volume

def attach_volume(volume, instance_id):
    wait_for_instance(instance_id)
    volume_desc = get_volume_desc(volume)
    volume_state = get_volume_state(volume)

    match volume_state:
        case 'available':
            msg(f'Attaching {volume_desc} to instance {instance_id}')
            return client('ec2').attach_volume(
                VolumeId=volume['VolumeId'],
                InstanceId=instance_id,
                Device=get_device_name(volume, instance_id))
        case 'creating' | 'in-use/detaching' | 'in-use/detached':
            dbg(f'{volume_desc} is still in state {volume_state}, waiting...')
            updated_volume = wait_for_volume(volume, wait_states = ['creating', 'in-use/detaching', 'in-use/detached'])
            return attach_volume(updated_volume, instance_id)
        case _:
            err(text = f'{volume_desc} is in state {volume_state} and can\'t be attached')

def detach_volume(volume):
    volume_desc = get_volume_desc(volume)

    match get_volume_state(volume):
        case 'in-use/attached':
            msg(f'Detaching {volume_desc}')
            ret = client('ec2').detach_volume(VolumeId=volume["VolumeId"])
            update_timestamp(volume['VolumeId'])
            return ret
        case 'in-use/detaching' | 'in-use/detached':
            dbg(f'{volume_desc} is already detaching, waiting...')
            wait_for_volume(volume, wait_states = ['in-use/detaching', 'in-use/detached'])
        case ('creating' | 'available' | 'deleting' | 'deleted') as state:
            dbg(f'{volume_desc} is in state {state}, nothing to do')
        case volume_state:
            err(text = f'{volume_desc} is in state {volume_state} and can\'t be detached')

def delete_volume(volume):
    volume_desc = get_volume_desc(volume)
    volume_state = get_volume_state(volume)

    match volume_state:
        case 'available':
            msg(f'Deleting {volume_desc}')
            return client('ec2').delete_volume(VolumeId=volume["VolumeId"])
        case 'deleted' | 'deleting':
            dbg(f'{volume_desc} is {volume_state}')
        case 'in-use/detaching':
            dbg(f'{volume_desc} is detaching, waiting...')
            updated_volume = wait_for_volume(volume, wait_states = [volume_state])
            return delete_volume(updated_volume)
        case _:
            err(text = f'{volume_desc} is in state {volume_state} and can\'t be deleted')

def create_snapshot(volume, snapshot_tags):
    snapshots = get_snapshots(snapshot_tags)

    if snapshots:
        err('SNAPSHOT_ALREADY_EXISTS')

    msg(f'Creating a snapshot with tags {get_tag_string(snapshot_tags)} from ' + get_volume_desc(volume))

    return client('ec2').create_snapshot(
        TagSpecifications=[{'ResourceType': 'snapshot', 'Tags': get_tag_spec(snapshot_tags)}],
        VolumeId=volume['VolumeId'])

def delete_snapshot(snapshot):
    msg(f'Deleting snapshot {snapshot["SnapshotId"]} with tags {get_tag_string(snapshot["Tags"])}')
    return client('ec2').delete_snapshot(SnapshotId=snapshot['SnapshotId'])

def format_volume(volume_id, fstype):
    try:
        device = get_disk(volume_id)
        msg(f'Formatting {device} ({volume_id})')
        run(['sudo', 'mkfs', '-t', fstype, device], capture_output=True, check=True)
    except CalledProcessError as e:
        err(f'mkfs failed with exit code {e.returncode}: {e.stderr.decode()}')

def mount(volume_id, mountpoint, fstype):
    device = get_disk(volume_id)

    try:
        for i in range(10):
            if exists(device):
                break
            else:
                dbg(f'Waiting for {device} to become available')
                sleep(10)

        p = run(['lsblk', '-n', '-o', 'fstype', device], capture_output=True, check=True)
        if not p.stdout.decode().strip():
            format_volume(volume_id, fstype)
    except CalledProcessError as e:
        err(f'lsblk failed with exit code {e.returncode}: {e.stderr.decode()}')

    msg(f'Mounting {device} ({volume_id}) at {mountpoint}')
    makedirs(mountpoint, exist_ok=True)

    try:
        cmd = ['sudo', 'mount', '-t', fstype, '-o', 'noatime', device, mountpoint]
        run(cmd, capture_output=True, check=True)
    except CalledProcessError as e:
        err(f'mount failed with exit code {e.returncode}: {e.stderr.decode()}')

def umount(mountpoint):
    msg(f'Unmounting {mountpoint}')
    try:
        run(['sudo', 'umount', mountpoint], capture_output=True, check=True)
    except CalledProcessError as e:
        err(f'umount failed with exit code {e.returncode}: {e.stderr.decode()}')

def instance_and_az_match(instance_id, availability_zone):
    if instance_id and availability_zone:
        if availability_zone != get_availability_zone(instance_id):
            err('AZ_DOES_NOT_MATCH_INSTANCE')

