toList = list

# TODO: enable choosing max verbosity on the command line
def msg(msg, log_level = 'info'):
    say = lambda m: print(m, file=sys.stderr)

    match log_level:
        case 'error':
            say(f'Error: {msg}')
            sys.exit(2)
        case 'info':
            say(msg)
        case 'debug':
            say(f'DEBUG: {msg}')
        case _:
            raise ValueError('Valid severities: error, info, debug')

def dbg(m):
    return msg(m, 'debug')

def err(template = None, text = None):
    if template:
        return msg({
            'ABORTED': 'Aborting on user request',
            'ATTACH_REQUIRES_REAL_TAGS': 'The attach action may create volumes, so it requires non-wildcard tags',
            'AZ_DOES_NOT_MATCH_INSTANCE': 'The specified availability zone does not match the instance',
            'MOUNTPOINT_WO_FSTYPE': 'If a mountpoint is specified, the filesystem type also needs to be specified',
            'NO_AVAILABLE_DEVICES': 'All available device names are in use on the target instance',
            'NO_ROOT': 'Please don\'t run this script as root, it will call sudo if necessary ((u)mount/format)',
            'NO_TAGS_SPECIFIED': 'This action requires --tags, or --snapshot-tags, or both',
            'NO_VOLUMES': 'No volumes found with the specified tags',
            'RESERVED_TAG': f'Tags starting with {PROG}. are reserved for internal use',
            'SNAPSHOT_ALREADY_EXISTS': 'A snapshot with tags the specified tags already exists',
            'SNAPSHOT_REQUIRES_REAL_TAGS': 'The snapshot action creates snapshots, so it requires non-wildcard snapshot tags',
            'TIMEOUT_PENDING_INSTANCE': 'Timed out waiting for a pending instance to become available',
            'TOO_MANY_VOLUMES': 'The number of volumes with the specified tags exceeds 1',
            'TOO_MANY_SNAPSHOTS_W_SNAPSHOT_TAGS': 'The number of snapshots with the specified tags exceeds 1',
            'TOO_MANY_SNAPSHOTS_W_VOLUME_TAGS': 'The number of snapshots with the specified tags exceeds 1',
            'VOLUME_EXISTS': 'A volume with the specified tags already exists',
            'b0rk': 'An impossible b0rkage has occurred',
        }[template], log_level = 'error')
    elif text:
        return msg(text, log_level = 'error')
    else:
        raise ValueError('Can\'t call this with empty arguments')

def get_tag_filters(tags):
    '''Dictionary to list of Name/Values dictionaries'''

    all_tags = IMPLICIT_TAGS | (tags if tags != '*' else {})
    return [{'Name': f'tag:{k}', 'Values': [v]} for k, v in all_tags.items()]

def get_tag_spec(tags):
    '''Dictionary to a list of Key/Value dictionaries'''

    all_tags = IMPLICIT_TAGS | (tags if tags != '*' else {})
    return [{'Key': k, 'Value': v} for k, v in all_tags.items()]

def get_tag_string(tags):
    '''Wildcard, or dictionary, or list of Key/Value dictionaries to comma-separated list of k=v pairs'''

    if not tags:
        return ''
    if tags == '*':
        return '*'
    elif isinstance(tags, dict):
        return ','.join(f'{k}={v}' for k, v in sorted(tags.items()) if k and not k.startswith(f'{PROG}.'))
    else:
        return ','.join(f'{t["Key"]}={t["Value"]}' for t in sorted(tags, key=itemgetter('Key')) if t and not t['Key'].startswith(f'{PROG}.'))

def get_tag_dict(tags):
    '''List of Key/Value dictionaries to dictionary'''

    return {t['Key']: t['Value'] for t in tags}

def get_disk(volume_id):
    return realpath(f'/dev/disk/by-id/nvme-Amazon_Elastic_Block_Store_{volume_id.replace("-", "")}')

def get_device_name(volume, instance_id):
    valid_letters = [chr(c) for c in range(ord('b'), ord('z') + 1)]
    default_letter = valid_letters[sum(ord(c) for c in toList(volume['VolumeId'])) % len(valid_letters)]
    instance = client('ec2').describe_instances(InstanceIds=[instance_id])['Reservations'][0]['Instances'][0]
    unavailable_letters = [m['DeviceName'][-1] for m in instance['BlockDeviceMappings']]
    available_letters = [letter for letter in valid_letters if letter not in unavailable_letters]

    if default_letter in available_letters:
        return f'/dev/xvd{default_letter}'
    elif available_letters:
        return f'/dev/xvd{random.choice(available_letters)}'
    else:
        err('NO_AVAILABLE_DEVICES')

def get_volumes(tags, availability_zone = None, only_active = True):
    dbg(f'Getting volumes with tags {get_tag_string(tags)}' +
       (f' in availability zone {availability_zone}' if availability_zone else ""))
    filters = get_tag_filters(tags) +\
        ([{'Name': 'availability-zone', 'Values': [availability_zone]}] if availability_zone else []) +\
        ([{'Name': 'status', 'Values': ['creating', 'available', 'in-use']}] if only_active else [])
    return client('ec2').describe_volumes(Filters=filters)['Volumes'] if tags else []

def get_volume(tags, availability_zone = None):
    match get_volumes(tags, availability_zone):
        case []:
            err('NO_VOLUMES')
        case [volume]:
            return volume
        case _:
            err('TOO_MANY_VOLUMES')

def get_volume_state(volume):
    suffix = f'/{volume["Attachments"][0]["State"]}' if 'Attachments' in volume and volume['Attachments'] else ''
    return f'{volume["State"]}{suffix}'

def get_volume_desc(volume):
    return f'volume {volume["VolumeId"]} with tags {get_tag_string(volume["Tags"])} in availability zone {volume["AvailabilityZone"]}'

def get_snapshots(snapshot_tags):
    dbg(f'Getting snapshots with tags {get_tag_string(snapshot_tags)}')
    return client('ec2').describe_snapshots(Filters=get_tag_filters(snapshot_tags))['Snapshots'] if snapshot_tags else []

def get_instance_id():
    def valid_instance_id(instance_id):
        if re.fullmatch(r'i-[0-9a-f]{8,}', instance_id):
            return instance_id
        raise ValueError(f'Invalid instance id: {instance_id}')

    try:
        dbg('Getting instance id from /var/lib/cloud/data/instance-id')
        with open('/var/lib/cloud/data/instance-id', 'r') as f:
            return valid_instance_id(f.read().strip())
    except Exception:
        dbg('Failed to get instance id from /var/lib/cloud/data/instance-id')
        try:
            dbg('Getting instance id from IMDS')
            imds='http://169.254.169.254/latest'
            read=lambda r: r.read(512).decode('utf-8')

            token_req = Request(f'{imds}/api/token', method='PUT', headers={'X-aws-ec2-metadata-token-ttl-seconds': '900'})
            with urlopen(token_req, timeout=10) as resp:
                id_req = Request(f'{imds}/meta-data/instance-id', headers={'X-aws-ec2-metadata-token': read(resp)})
                with urlopen(id_req, timeout=10) as resp2:
                    return valid_instance_id(read(resp2))
        except Exception as e:
            err(text=f'Failed to get instance id from IMDS: {e}')

def get_instance_state(instance_id):
    dbg(f'Getting instance state for {instance_id}')
    return client('ec2').describe_instances(InstanceIds=[instance_id])['Reservations'][0]['Instances'][0]['State']['Name']

def get_availability_zone(instance_id):
    dbg(f'Getting availability zone for instance {instance_id}')
    return client('ec2').describe_instances(InstanceIds=[instance_id])['Reservations'][0]['Instances'][0]['Placement']['AvailabilityZone']

def update_timestamp(volume_id):
    dbg(f'Updating the timestamp on volume {volume_id}')
    return client('ec2').create_tags(
        Resources=[volume_id],
        Tags=[{'Key': f'{PROG}.updated', 'Value': datetime.now(UTC).isoformat()}])

def wait_for_volume(volume, valid_states = ['available'], wait_states = [], timeout_sec = 600, step_sec = 10):
    volume_state = get_volume_state(volume)
    valid_states_str = ', '.join(valid_states)

    if volume_state in valid_states:
        return volume
    elif volume_state in wait_states:
        if timeout_sec <= 0:
            err(text = f'Timed out waiting for {get_volume_desc(volume)} to enter a valid state ({valid_states})')
        else:
            dbg(f'Waiting for volume {get_volume_desc(volume)}, currently in state {volume_state} for {step_sec}s ' +
                f'until it reaches a valid state ({valid_states_str}) ({timeout_sec - step_sec}s left)')
            sleep(step_sec)
            return wait_for_volume(get_volume(get_tag_dict(volume['Tags']), volume['AvailabilityZone']), valid_states, wait_states, timeout_sec - step_sec, step_sec)
    else:
        err(text = f'Volume {volume["VolumeId"]} is in an invalid state {volume_state}')

def wait_for_instance(instance_id, timeout_sec = 600):
    match get_instance_state(instance_id):
        case 'running' | 'stopped':
            return
        case 'pending':
            if timeout_sec <= 0:
                err('TIMEOUT_PENDING_INSTANCE')
            else:
                dbg(f'Instance {instance_id} is still in state "pending", waiting 10s...')
                sleep(10)
                return wait_for_instance(instance_id, timeout_sec - 10)
        case error_state:
            err(text = f'instance {instance_id} is in state {error_state}, so the volume can\'t be attached')

# TODO: maybe have a minimum window of difference for a snapshot to be used instead of a volume
def use_newer(volume, snapshot, options):
    if snapshot['State'] == 'completed':
        tags = get_tag_dict(volume['Tags'])
        volume_timestamp = isoparse(tags[f'{PROG}.updated']) if f'{PROG}.updated' in tags.keys() else volume['CreateTime']
        if volume_timestamp >= snapshot['StartTime']:
            dbg(f'Using existing {get_volume_desc(volume)}')
            return volume
        else:
            dbg(f'Using a new volume from a newer snapshot than {get_volume_desc(volume)}')
            delete_volume(volume)
            return create_volume(**options | {'snapshot': snapshot})
    else:
        dbg(f'Using existing {get_volume_desc(volume)}, the snapshot {snapshot["SnapshotId"]} is in state ({snapshot["State"]})')
        return volume

