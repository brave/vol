# TODO: show also the instance id when the volume is mounted
def list(tags, snapshot_tags, availability_zone):
    if not tags and not snapshot_tags:
        err('NO_TAGS_SPECIFIED')

    volumes_result = {
        'volumes': {
            v['VolumeId']: {
                'state': v['State'],
                'availability-zone': v['AvailabilityZone'],
                'tags': get_tag_string(v['Tags']),
                'updated': get_tag_dict(v['Tags']).get(f'{PROG}.updated', v['CreateTime'])
            } | ({'snapshot-id': v['SnapshotId']} if v['SnapshotId'] else {}) for v in get_volumes(tags, availability_zone, only_active=False)
        }
    } if tags else {}

    snapshots_result = {
        'snapshots': {
            s['SnapshotId']: {
                'state': s['State'],
                'volume-id': s['VolumeId'],
                'tags': get_tag_string(s['Tags']),
                'created': s['StartTime'],
            } for s in get_snapshots(snapshot_tags)
        }
    } if snapshot_tags else {}

    return volumes_result | snapshots_result

def attach(tags, snapshot_tags, instance_id, availability_zone, wipe, size, kms_key_id,
           mountpoint, fstype, no_snapshots, volume_initialization_rate):
    if wipe:
        match get_volumes(tags, availability_zone):
            case [vol]:
                delete_volume(vol)

    options = {
        'availability_zone': availability_zone,
        'kms_key_id': kms_key_id,
        'size': size,
        'tags' : tags,
        'snapshot': None,
        'volume_initialization_rate': volume_initialization_rate,
    }

    match get_volumes(tags, availability_zone), get_snapshots(tags), (get_snapshots(snapshot_tags) if snapshot_tags else []):
        case [vol], [], _:
            volume = vol
        case [vol], [snapshot], _:
            volume = use_newer(vol, snapshot, options) if not no_snapshots else vol
        case ([], [snapshot], _) | ([], [], [snapshot]):
            volume = create_volume(**options | {'snapshot': snapshot if snapshot['State'] == 'completed' and not no_snapshots else None})
        case [], [], []:
            volume = create_volume(**options)
        case [_, _, *_], _, _:
            err('TOO_MANY_VOLUMES')
        case _, [_, _, *_], _:
            err('TOO_MANY_SNAPSHOTS_W_VOLUME_TAGS')
        case _, _, [_, _, *_]:
            err('TOO_MANY_SNAPSHOTS_W_SNAPSHOT_TAGS')
        case _:
            err('b0rk')

    result = attach_volume(volume, instance_id)

    if mountpoint:
        mount(volume['VolumeId'], mountpoint, fstype)

    return result

def detach(tags, availability_zone, wipe, mountpoint):
    volume = get_volume(tags, availability_zone)

    if mountpoint:
        umount(mountpoint)

    result = detach_volume(volume)

    if wipe:
        delete_volume(volume)

    return result

def snapshot(tags, snapshot_tags, no_clobber, availability_zone):
    volume = get_volume(tags, availability_zone)

    match get_snapshots(snapshot_tags):
        case []:
            return create_snapshot(volume, snapshot_tags)
        case [snapshot]:
            if no_clobber:
                err('SNAPSHOT_ALREADY_EXISTS')
            else:
                delete_snapshot(snapshot)

            return create_snapshot(volume, snapshot_tags)
        case _:
            err('TOO_MANY_SNAPSHOTS_W_SNAPSHOT_TAGS')

def clean(tags, snapshot_tags, availability_zone, interactive):
    if not tags and not snapshot_tags:
        err('NO_TAGS_SPECIFIED')

    msg('Deleting the following resources')
    print_result(list(tags, snapshot_tags, availability_zone))

    if interactive:
        # TODO: add timeout
        answer = input('Confirm? [Y/n] ')

    if not interactive or answer in ['', 'y', 'Y', 'yes', 'Yes', 'YES']:
        # TODO: don't fail if one operation fails
        volumes_result = {
            'volumes': [delete_volume(v) for v in get_volumes(tags, availability_zone)]
        } if tags else {}

        snapshots_result = {
            'snapshots': [delete_snapshot(s) for s in get_snapshots(snapshot_tags)]
        } if snapshot_tags else {}

        return volumes_result | snapshots_result
    else:
        err('ABORTED')

#################################### MAIN #####################################

def main():
    args = get_args()

    # Fail if executed as root
    if getuid() == 0 or getgid() == 0:
        err('NO_ROOT')

    # TODO: check tags for invalid characters and fail early
    # Fail if reserved tags are used
    check_tags = (args.tags if "tags" in args and args.tags and args.tags != '*' else {}) |\
        (args.snapshot_tags if "snapshot_tags" in args and args.snapshot_tags and args.snapshot_tags != '*' else {})
    if next((k for k, v in check_tags.items() if k.startswith(f'{PROG}.')), None):
        err('RESERVED_TAG')

    if args.action in ['attach', 'detach', 'snapshot']:
        instance_id = args.instance_id or get_instance_id()
        availability_zone = args.availability_zone or get_availability_zone(instance_id)

    # Execute the action
    match args.action:
        case 'list':
            print_result(list(args.tags, args.snapshot_tags, args.availability_zone))
        case 'attach':
            if args.tags == '*':
                err('ATTACH_REQUIRES_REAL_TAGS')
            if args.mountpoint and not args.fstype:
                err('MOUNTPOINT_WO_FSTYPE')
            instance_and_az_match(args.instance_id, args.availability_zone)

            extra_args = { 'instance_id': instance_id, 'availability_zone': availability_zone }
            arg_names = ['tags', 'snapshot_tags', 'wipe', 'size', 'kms_key_id', 'mountpoint',
                         'fstype', 'no_snapshots', 'volume_initialization_rate']

            print_result(attach(**{k: getattr(args, k) for k in arg_names} | extra_args))
        case 'detach':
            instance_and_az_match(args.instance_id, args.availability_zone)
            print_result(detach(args.tags, availability_zone, args.wipe, args.mountpoint))
        case 'snapshot':
            if args.tags == '*':
                err('SNAPSHOT_REQUIRES_REAL_TAGS')

            print_result(snapshot(args.tags, args.snapshot_tags, args.no_clobber, availability_zone))
        case 'clean':
            print_result(clean(args.tags, args.snapshot_tags, args.availability_zone, args.interactive))
        case _:
            err('b0rk')

if __name__ == '__main__':
    main()
