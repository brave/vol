PROG = 'vol'
IMPLICIT_TAGS = {f'{PROG}.namespace': 'default'}

def get_args():
    class HelpFormatter(argparse.ArgumentDefaultsHelpFormatter, argparse.RawDescriptionHelpFormatter): pass

    parser = argparse.ArgumentParser(prog=PROG, formatter_class=HelpFormatter, description=dedent(f'''
        Tag-based EBS volume management

        The script can be invoked on the node, or off (except (u)mount/format)

        Reserved tags starting with `{PROG}.' are added to volumes and
        snapshots, used in queries and are filtered out before display

        The script enforces the requirement that a search by tags must return
        at most one result for snapshots and per-availability-zone for volumes
        (except clean/list)
    '''))

    tag_type = lambda s: s if s == '*' else dict(map(lambda p: p.split('='), s.split(',')))

    options = (
        (
            'list',
            'list',
            '''
                * list volumes matching the specified tags (and optionally availability zone)
                * list snapshots matching the specified snapshot tags

                E.g.:

                %(prog)s --tags type=bb.pr.workspace,pr=123

                %(prog)s --tags '*' --snapshot-tags '*'
            ''',
            (
                (['-t', '--tags'], {'type': tag_type, 'help': 'match volume tags: t1=v1,...,tN=vN'}),
                (['-T', '--snapshot-tags'], {'type': tag_type, 'help': 'match snapshot tags: t1=v1,...,tN=vN'}),
                (['-z', '--availability-zone'], {'help': 'availability zone for volumes, any if not set'}),
            ),
        ),
        (
            'attach',
            'delete/create/attach/mount',
            '''
                * if wipe is specified, delete the volume with the specified tags in the specified availability zone
                * find any volume with the specified tags and availability zone and any snapshots with the specified tags
                  * if the volume is newer
                    * attach it
                  * if the snapshot with the specified tags is newer (1)
                    * delete any existing volume with the specified tags and availability zone
                    * create a volume with the specified tags and availability zone from that snapshot
                    * attach it
                  * if neither exists
                    * if a snapshot with the specified snapshot tags exists
                      * create a volume with the specified tags and availability zone from that snapshot
                      * attach it
                    * otherwise
                      * create an empty volume with the specified size, tags and availability zone
                      * attach it
                * optionally mount, if running on the instance
                  * if the volume is not formatted, format it

                (1) if you want to attach cross-az, create snapshots, or you'll keep starting with an empty volume

                E.g.:

                %(prog)s \\
                    --tags type=bb.pr.workspace,pr=123,platform=linux,arch=x64 \\
                    --snapshot-tags type=bb.public.workspace,branch=master,platform=linux,arch=x64 \\
                    --size 256 \\
                    --mountpoint /home/ubuntu/workspace
            ''',
            (
                (['-f', '--fstype'], {'default': 'ext4', 'help': 'fs type to use with --mountpoint if the volume is not formatted'}),
                (['-i', '--instance-id'], {'help': 'instance id, current instance by default'}),
                (['-k', '--kms-key-id'], {'help': 'KMS key to use for volume encryption, otherwise default'}),
                (['-m', '--mountpoint'], {'help': 'mountpoint, only on <instance-id>, requires util-linux, create if doesn\'t exist'}),
                (['-n', '--no-snapshots'], {'type': bool, 'default': False, 'help': 'do not use snapshots to create volumes'}),
                (['-r', '--volume-initialization-rate'], {'type': int, 'default': None, 'help': 'volume initialization rate in MiB/s'}),
                (['-s', '--size'], {'type': int, 'required': True, 'help': 'volume size in GB, if it needs to be created'}),
                (['-t', '--tags'], {'type': tag_type, 'required': True, 'help': 'match volume tags: t1=v1,...,tN=vN'}),
                (['-T', '--snapshot-tags'], {'type': tag_type, 'help': 'match snapshot tags: t1=v1,...,tN=vN'}),
                (['-w', '--wipe'], {'type': bool, 'default': False, 'help': 'delete the matching volume first'}),
                (['-z', '--availability-zone'], {'help': 'availability zone, derived from instance-id if not set'}),
            ),
        ),
        (
            'detach',
            'umount/detach/delete',
            '''
                * optionally umount, if running on the instance
                * detach the volume
                * if wipe is specified, delete the volume

                E.g.:

                %(prog)s \\
                    --tags type=bb.pr.workspace,pr=123,platform=linux,arch=x64 \\
                    --mountpoint /home/ubuntu/workspace
            ''',
            (
                (['-i', '--instance-id'], {'help': 'instance id, current instance by default, used to derive az if not set'}),
                (['-m', '--mountpoint'], {'help': 'mountpoint, only on <instance-id>, requires util-linux'}),
                (['-t', '--tags'], {'type': tag_type, 'default': [], 'help': 'match volume tags: t1=v1,...,tN=vN'}),
                (['-w', '--wipe'], {'type': bool, 'default': False, 'help': 'delete the matching volume'}),
                (['-z', '--availability-zone'], {'help': 'availability zone, required, derived from instance-id if not set'}),
            ),
        ),
        (
            'snapshot',
            'create/overwrite',
            '''
                * create a snapshot of a volume
                * if the snapshot with the specified tags exists, overwrite, unless --no-clobber is used

                E.g.:

                %(prog)s \\
                    --tags          type=bb.public.workspace,branch=master,platform=linux,arch=x64 \\
                    --snapshot-tags type=bb.public.workspace,branch=master,platform=linux,arch=x64
            ''',
            (
                (['-i', '--instance-id'], {'help': 'instance id, current instance by default, used to derive az if not set'}),
                (['-n', '--no-clobber'], {'type': bool, 'default': False, 'help': 'do not overwrite existing snapshots'}),
                (['-t', '--tags'], {'type': tag_type, 'default': [], 'help': 'match volume tags: t1=v1,...,tN=vN'}),
                (['-T', '--snapshot-tags'], {'type': tag_type, 'required': True, 'help': 'match snapshot tags: t1=v1,...,tN=vN'}),
                (['-z', '--availability-zone'], {'help': 'availability zone, required, derived from instance-id if not set'}),
            ),
        ),
        (
            'clean',
            'delete',
            '''
                * delete volumes matching the specified tags (and optionally availability zone)
                * delete snapshots matching the specified snapshot tags

                E.g.:

                %(prog)s --tags type=bb.pr.workspace,pr=123,platform=linux,arch=x64
            ''',
            (
                (['-i', '--interactive'], {'type': bool, 'default': False, 'help': 'interactively ask for input'}),
                (['-t', '--tags'], {'type': tag_type, 'help': 'match volume tags: t1=v1,...,tN=vN'}),
                (['-T', '--snapshot-tags'], {'type': tag_type, 'help': 'match snapshot tags: t1=v1,...,tN=vN'}),
                (['-z', '--availability-zone'], {'help': 'availability zone for volumes, any if not set'}),
            ),
        ),
    )

    subparsers = parser.add_subparsers(title='action', dest='action', required=True, description='%(prog)s <action> -h for more help')

    for action, help, description, opts in options:
        action_description = dedent(description)
        action_parser = subparsers.add_parser(action, description=action_description, help=help, formatter_class=HelpFormatter)
        for ar, kwar in opts:
            action_parser.add_argument(*ar, **kwar)

    # TODO: enable reading options from a config file, including restrictions on valid tag keys/values

    return parser.parse_args()

